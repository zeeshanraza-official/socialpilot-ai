# ============================================================
# SOCIALPILOT AI - Environment Variables Template
# Copy to .env.local and fill in all values
# NEVER commit .env.local to version control
# ============================================================

# ---- SUPABASE ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# ---- APP ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET_KEY=your-32-char-minimum-secret-key-here
TOKEN_ENCRYPTION_KEY=your-32-char-token-encryption-key

# ---- AWS S3 ----
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-socialpilot-bucket
AWS_CLOUDFRONT_URL=https://your-distribution.cloudfront.net

# ---- OPENAI ----
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# ---- SOCIAL PLATFORM APIs (Server-side only) ----
# Facebook / Meta
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET

# LinkedIn
LINKEDIN_CLIENT_ID=YOUR_LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=YOUR_LINKEDIN_CLIENT_SECRET

# YouTube / Google
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ---- REDIS (for job queue) ----
REDIS_URL=redis://localhost:6379

# ---- RATE LIMITING ----
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ---- QUEUE ----
QUEUE_CONCURRENCY=5
SCHEDULER_INTERVAL_MS=60000
